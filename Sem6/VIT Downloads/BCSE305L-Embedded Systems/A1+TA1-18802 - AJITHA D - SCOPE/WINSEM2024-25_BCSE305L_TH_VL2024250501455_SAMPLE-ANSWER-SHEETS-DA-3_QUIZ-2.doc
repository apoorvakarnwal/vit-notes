    <!--Institution: --><!--Moodle language: en--><!--Moodle URL: https://moovit.vit.ac.in/--><!--Course name: BCSE305L Embedded Systems (Theory) Winter 2024-25 (A1+TA1) [VL2024250501434]--><!--Course ID: 17138--><!--Author name: DR. SHOBHA REKH 18803--><!--Author ID: --><!--Author username: 18803--><!--Image handling: embedded--><!--Contains embedded images: 0--><container>
<title>BCSE305L Embedded Systems (Theory) Winter 2024-25 (A1+TA1) [VL2024250501434], Category: top/Default for BCSE305L_VL2024250501434</title><p class="MsoTitle">BCSE305L Embedded Systems (Theory) Winter 2024-25 (A1+TA1) [VL2024250501434]</p><h1 class="MsoHeading1">top/Default for BCSE305L_VL2024250501434</h1><h2 class="MsoHeading2">10</h2><p class="MsoBodyText"/><div class="TableDiv">
<table border="1" dir="ltr"><thead>
<tr>
<td colspan="3" style="width: 12.0cm"><div class="chapter"><p class="MsoListParagraph" style="text-indent: -18.0pt; mso-list: l0 level1 lfo1;">&lt;!-- [if !supportLists]--&gt;<span lang="EN-GB" style="mso-bidi-font-family: Aptos; mso-bidi-theme-font: minor-latin; mso-ansi-language: EN-GB;"><span style="mso-list: Ignore;">1.<span style="font: 7.0pt 'Times New Roman';">       </span></span></span>&lt;!--[endif]--&gt;<span lang="EN-GB" style="mso-ansi-language: EN-GB;">Find the resolution % <span style="mso-spacerun: yes;"> </span>of a 3 bit DAC <span style="mso-spacerun: yes;"> </span>if the reference voltage is 1v.</span></p></div></td>
<td style="width: 1.0cm"><p class="QFType">MC</p></td></tr>
<tr>
<td colspan="3" style="width: 12.0cm"><p class="TableRowHead" style="text-align: right">Default mark:</p></td>
<td style="width: 1.0cm"><p class="Cell">1</p></td></tr>
<tr>
<td colspan="3" style="width: 12.0cm"><p class="TableRowHead" style="text-align: right">Shuffle the choices?</p></td>
<td style="width: 1.0cm"><p class="Cell">Yes</p></td></tr>
<tr>
<td colspan="3" style="width: 12.0cm"><p class="TableRowHead" style="text-align: right">Number the choices?</p></td>
<td style="width: 1.0cm"><p class="Cell">a</p></td></tr>
<tr>
<td colspan="3" style="width: 12.0cm"><p class="TableRowHead" style="text-align: right">Penalty for each incorrect try:</p></td>
<td style="width: 1.0cm"><p class="Cell">33.3</p></td></tr>

<tr>
<td colspan="3" style="width: 12.0cm"><p class="TableRowHead" style="text-align: right">ID number:</p></td>
<td style="width: 1.0cm"><p class="QFID"> </p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="QFOptionReset">#</p></td>
<td style="width: 5.0cm"><p class="TableHead">Answers</p></td>
<td style="width: 6.0cm"><p class="TableHead">Feedback</p></td>
<td style="width: 1.0cm"><p class="TableHead">Grade</p></td></tr>
</thead><tbody>
<tr>
<td style="width: 1.0cm"><p class="QFOption"> </p></td>
<td style="width: 5.0cm"><div class="chapter"><p class="MsoBodyText">10</p></div></td>
<td style="width: 6.0cm"><div class="chapter"><p class="QFFeedback"> </p></div></td>
<td style="width: 1.0cm"><p class="QFGrade">0</p></td></tr><tr>
<td style="width: 1.0cm"><p class="QFOption"> </p></td>
<td style="width: 5.0cm"><div class="chapter"><p class="MsoBodyText">8</p></div></td>
<td style="width: 6.0cm"><div class="chapter"><p class="QFFeedback"> </p></div></td>
<td style="width: 1.0cm"><p class="QFGrade">0</p></td></tr><tr>
<td style="width: 1.0cm"><p class="QFOption"> </p></td>
<td style="width: 5.0cm"><div class="chapter"><p class="MsoBodyText">12</p></div></td>
<td style="width: 6.0cm"><div class="chapter"><p class="QFFeedback"> </p></div></td>
<td style="width: 1.0cm"><p class="QFGrade">0</p></td></tr><tr>
<td style="width: 1.0cm"><p class="QFOption"> </p></td>
<td style="width: 5.0cm"><div class="chapter"><p class="MsoBodyText">14</p></div></td>
<td style="width: 6.0cm"><div class="chapter"><p class="QFFeedback"> </p></div></td>
<td style="width: 1.0cm"><p class="QFGrade">100</p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="Cell"> </p></td>
<th style="width: 5.0cm"><p class="TableRowHead"><p class="TableRowHead">General feedback:</p></p></th>
<td style="width: 6.0cm"><div class="chapter"><p class="Cell"> </p></div></td>
<td style="width: 1.0cm"><p class="Cell"> </p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="Cell"> </p></td>
<th style="width: 5.0cm"><p class="TableRowHead"><p class="TableRowHead">For any correct response:</p></p></th>
<td style="width: 6.0cm"><div class="chapter"><p class="MsoBodyText">Your answer is correct.</p></div></td>
<td style="width: 1.0cm"><p class="Cell"> </p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="Cell"> </p></td>
<th style="width: 5.0cm"><p class="TableRowHead"><p class="TableRowHead">For any incorrect response:</p></p></th>
<td style="width: 6.0cm"><div class="chapter"><p class="MsoBodyText">Your answer is incorrect.</p></div></td>
<td style="width: 1.0cm"><p class="Cell"> </p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="Cell"> </p></td>
<th style="width: 5.0cm"><p class="TableRowHead"><p class="TableRowHead">Hint 1:</p></p></th>
<td style="width: 6.0cm"><p class="Cell"> </p></td>
<td style="width: 1.0cm"><p class="Cell"> </p></td></tr>
<tr>
<td style="width: 1.0cm"><p class="Cell"> </p></td>
